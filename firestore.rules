// ============================================================================
// TEMPORARY FIRESTORE SECURITY RULES
// ============================================================================
// These rules enable login and basic functionality while the /userProfiles
// mirror collection is being populated via the backfill script.
//
// After running the backfill script and verifying data, deploy the production
// rules from firestore.rules.production instead.
// ============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helpers (align with production for admin-on-behalf updates) ─────
    function getUserProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuthenticated() && getUserProfile().role == "admin";
    }
    function isCompanyAdmin() {
      return isAuthenticated() && getUserProfile().role == "company_admin";
    }
    function myUserDocId() {
      return isAuthenticated() && getUserProfile().userDocId is string
        ? getUserProfile().userDocId
        : "";
    }
    function userDocEmailMatchesToken() {
      return isAuthenticated()
        && request.auth.token.email is string
        && resource.data.email is string
        && resource.data.email.lower() == request.auth.token.email.lower();
    }
    function inviteDocEmailMatchesToken() {
      return isAuthenticated()
        && request.auth.token.email is string
        && resource.data.email is string
        && resource.data.email.lower() == request.auth.token.email.lower();
    }
    
    // ─── userProfiles Collection (Mirror) ─────────────────────────────────
    // Keyed by authUid - used for security rules lookups
    // Read: user can read their own profile
    // Write: only via server-side (admin SDK) or auth context on login
    match /userProfiles/{authUid} {
      allow read: if request.auth != null && request.auth.uid == authUid;
      allow write: if request.auth != null && request.auth.uid == authUid;
    }
    
    // ─── Users Collection ─────────────────────────────────────────────────
    // Users can read any user doc (needed for login flow to find profile by authId)
    // Users can only update their own profile (where authId matches)
    match /users/{userId} {
      allow read: if request.auth != null && (
        userDocEmailMatchesToken() ||
        resource.data.authId == request.auth.uid ||
        isSuperAdmin() ||
        (isCompanyAdmin() && resource.data.organizationId == getUserProfile().organizationId)
      );
      allow update: if request.auth != null && (
        userDocEmailMatchesToken() ||
        resource.data.authId == request.auth.uid ||
        isSuperAdmin() ||
        (isCompanyAdmin() && resource.data.organizationId == getUserProfile().organizationId)
      );
      allow create, delete: if isSuperAdmin();
    }
    
    // ─── Responses Collection ─────────────────────────────────────────────
    match /responses/{responseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow updates when response.userId matches either auth UID (legacy) or the mirrored userDocId (current app)
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.userId == myUserDocId()
      );
      allow delete: if false;
    }
    
    // ─── Organizations ────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // ─── Templates ────────────────────────────────────────────────────────
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // ─── Schedules ────────────────────────────────────────────────────────
    match /schedules/{scheduleId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // ─── Settings ─────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // ─── Invites ──────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if request.auth != null && (
        inviteDocEmailMatchesToken() ||
        isSuperAdmin() ||
        (isCompanyAdmin() && resource.data.organizationId == getUserProfile().organizationId)
      );
      allow delete: if request.auth != null && inviteDocEmailMatchesToken();
      allow create, update: if false; // Admin SDK only
    }
    
    // ─── Report History ───────────────────────────────────────────────────
    match /report_history/{reportId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── Webinars ─────────────────────────────────────────────────────────
    match /webinars/{webinarId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── Scorecards ───────────────────────────────────────────────────────
    match /scorecards/{scorecardId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── Aggregates (pre-computed dashboard stats from cron/backfill)
    match /aggregates/{aggregateId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK / aggregate endpoint only
    }

    // ─── Deny All Other Collections ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
