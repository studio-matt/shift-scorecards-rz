rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - needed for login flow
    // Users can read any user doc (to find their profile by authId)
    // Users can only update their own profile (where authId matches their Firebase Auth UID)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && resource.data.authId == request.auth.uid;
      allow create, delete: if false; // Admins use server-side admin SDK for these
    }
    
    // Responses collection - users can read/write their own responses
    match /responses/{responseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    
    // Organizations - read-only for authenticated users
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // Templates - read-only for authenticated users
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // Settings - read-only for authenticated users
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // Report history - read-only for authenticated users
    match /reportHistory/{reportId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
