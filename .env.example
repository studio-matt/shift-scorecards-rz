# Vercel / server (cron + firebase-admin). Copy to `.env.local` for local cron tests only — never commit real secrets.
# Production (Firebase App Hosting): cron is Google Cloud Scheduler POST only — see VERCEL_CRON_NOT_USED.txt — not Vercel cron.

# Bearer token Cloud Scheduler / manual sends (must match App Hosting CRON_SECRET):
# Authorization: Bearer <CRON_SECRET> (must match Firebase App Hosting → Backend → CRON_SECRET)
# To sync Scheduler after changing CRON_SECRET: scripts/gcloud-scheduler-set-cron-bearer.sh
CRON_SECRET=

# Manual triggers: POST /api/cron/aggregate-responses with header X-Backfill-Secret
BACKFILL_SECRET=

# Service account JSON as a single-line string (used by firebase-admin `getAdminDb`)
FIREBASE_SERVICE_ACCOUNT_KEY=
